# Caosmos Environment Variables

# Google Gemini API Configuration
GOOGLE_AI_API_KEY=your_api_key_here
GOOGLE_AI_MODEL=gemini-3.1-flash-lite-preview

# --- NEW: Ollama ---
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen3.5:9b

# --- NEW: OpenAI ---
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# --- NEW: Multi-Model Universe (overrides per channel) ---
# Thinking channel (ciudadanos) — default: usa GOOGLE_AI_API_KEY / GOOGLE_AI_MODEL
CAOSMOS_THINKING_PROVIDER=gemini       # gemini | ollama | openai
CAOSMOS_THINKING_API_KEY=
CAOSMOS_THINKING_BASE_URL=
CAOSMOS_THINKING_MODEL=

# Director channel (arbitraje/observación) — default: usa GOOGLE_AI_API_KEY / GOOGLE_AI_MODEL
CAOSMOS_DIRECTOR_PROVIDER=gemini       # gemini | ollama | openai
CAOSMOS_DIRECTOR_API_KEY=
CAOSMOS_DIRECTOR_BASE_URL=
CAOSMOS_DIRECTOR_MODEL=

# Optional: Spring Profiles
# SPRING_PROFILES_ACTIVE=docker

# Port Configuration
HOST_PORT=8080
CONTAINER_PORT=8080
